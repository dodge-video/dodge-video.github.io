---
// SPDX-License-Identifier: PolyForm-Noncommercial-1.0.0
// Required Notice: Copyright 2026 Ethan Witwer (https://dodge.video)

import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  kicker?: string;
}

const { title, description, kicker } = Astro.props;
---
<BaseLayout title={`${title} - dodge.video`} description={description}>
  <article>
    {kicker && <div class="kicker mono">{kicker}</div>}
    <h1>{title}</h1>
    {description && <p class="lede">{description}</p>}
    <div class="body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  article {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 48px 56px;
    margin-top: 24px;
  }
  .kicker {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 12px;
    text-transform: uppercase;
  }
  h1 {
    font-size: 36px;
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 0 0 14px;
    font-weight: 700;
  }
  .lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0 0 28px;
    max-width: 64ch;
  }
  .body :global(h2) {
    font-size: 22px;
    margin: 32px 0 12px;
    font-weight: 700;
    letter-spacing: -0.005em;
  }
  .body :global(h3) {
    font-size: 17px;
    margin: 24px 0 8px;
    font-weight: 700;
  }
  .body :global(p) {
    margin: 0 0 14px;
    max-width: 70ch;
    line-height: 1.65;
  }
  .body :global(a) {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }
  .body :global(ul),
  .body :global(ol) {
    margin: 0 0 14px;
    padding-left: 22px;
  }
  .body :global(li) {
    margin-bottom: 6px;
  }
  .body :global(code) {
    font-family: 'JetBrains Mono', monospace;
    background: var(--code-bg);
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 0.92em;
  }
  .body :global(pre) {
    font-family: 'JetBrains Mono', monospace;
    background: var(--code-bg);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 14px 18px;
    overflow-x: auto;
    font-size: 13px;
  }
  .body :global(pre code) {
    background: transparent;
    padding: 0;
  }
  .body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 18px;
    font-size: 14px;
  }
  .body :global(th),
  .body :global(td) {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line-soft);
    vertical-align: top;
  }
  .body :global(th) {
    font-weight: 600;
    color: var(--ink);
    background: #fafbfc;
    border-bottom-color: var(--line);
    font-size: 13px;
    letter-spacing: 0.02em;
  }
  @media (max-width: 800px) {
    article {
      padding: 32px 24px;
    }
    h1 {
      font-size: 28px;
    }
  }
</style>
