import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

const posts = (await getCollection('news', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<PageLayout
  kicker="NEWS"
  title="News from the Dodge project"
  description="Announcements, new defense designs, deployment reports, and research."
>
  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <a href={`/news/${post.id}`}>
          <span class="date mono">
            {post.data.date.toLocaleDateString('en-CA')}
          </span>
          <span class="title">{post.data.title}</span>
        </a>
        <p class="blurb">{post.data.description}</p>
      </li>
    ))}
    {posts.length === 0 && <li class="empty">No posts yet.</li>}
  </ul>
  <p class="rss"><a href="/news/rss.xml">RSS feed</a></p>
</PageLayout>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-list li {
    padding: 16px 0;
    border-bottom: 1px solid var(--line-soft);
  }
  .post-list li:last-child {
    border-bottom: 0;
  }
  .post-list a {
    display: flex;
    gap: 18px;
    align-items: baseline;
    text-decoration: none;
    border-bottom: 0 !important;
  }
  .post-list a:hover .title {
    color: var(--accent);
  }
  .date {
    color: var(--muted);
    font-size: 12px;
    min-width: 96px;
  }
  .title {
    font-size: 17px;
    font-weight: 700;
    color: var(--ink);
  }
  .blurb {
    color: var(--muted);
    margin: 4px 0 0 114px !important;
    font-size: 14px;
    max-width: 70ch;
  }
  .rss {
    margin-top: 28px !important;
    font-size: 13px;
    font-family: 'JetBrains Mono', monospace;
  }
  @media (max-width: 600px) {
    .post-list a {
      flex-direction: column;
      gap: 4px;
    }
    .blurb {
      margin-left: 0 !important;
    }
  }
</style>
