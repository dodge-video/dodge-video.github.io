      <rect class="seg" x="208" y="10" width="14" height="18" />
      <rect class="seg" x="224" y="6" width="14" height="22" />
      <rect class="seg" x="240" y="14" width="14" height="14" />
      <rect class="seg" x="256" y="4" width="14" height="24" />
      <rect class="seg" x="272" y="2" width="14" height="26" />
      <rect class="seg" x="288" y="10" width="14" height="18" />
      <rect class="seg" x="304" y="6" width="14" height="22" />
    </g>
    <text class="lbl-strong" x="10" y="98">title_B</text>
    <g transform="translate(110,80)">
      <rect class="seg" x="0" y="0" width="14" height="28" />
      <rect class="seg" x="16" y="14" width="14" height="14" />
      <rect class="seg" x="32" y="6" width="14" height="22" />
      <rect class="seg" x="48" y="18" width="14" height="10" />
      <rect class="seg" x="64" y="2" width="14" height="26" />
      <rect class="seg" x="80" y="22" width="14" height="6" />
      <rect class="seg" x="96" y="0" width="14" height="28" />
      <rect class="seg" x="112" y="16" width="14" height="12" />
      <rect class="seg" x="128" y="6" width="14" height="22" />
      <rect class="seg" x="144" y="20" width="14" height="8" />
      <rect class="seg" x="160" y="0" width="14" height="28" />
      <rect class="seg" x="176" y="14" width="14" height="14" />
      <rect class="seg" x="192" y="22" width="14" height="6" />
    </g>
    <text class="lbl-strong" x="10" y="168">title_C</text>
    <g transform="translate(110,150)">
      <rect class="seg" x="0" y="10" width="14" height="18" />
      <rect class="seg" x="16" y="6" width="14" height="22" />
      <rect class="seg" x="32" y="2" width="14" height="26" />
