// fig 02 - three titles, distinct fingerprints. Each title is a row of bars.
---
<figure class="visual-frame">
  <div class="vlabel mono">
    <span>fig 02 · three titles · same network observer</span>
    <span>distinct identities</span>
  </div>
  <svg
    viewBox="0 0 640 220"
    width="100%"
    height="auto"
    role="img"
    aria-label="Three rows of bar charts labeled title_A, title_B, title_C. Each row has a distinct sequence of segment sizes, illustrating that different videos produce identifiable fingerprints. The rows also have different lengths."
  >
    <text class="lbl-strong" x="10" y="28">title_A</text>
    <g transform="translate(110,10)">
      <rect class="seg" x="0" y="6" width="14" height="22" />
      <rect class="seg" x="16" y="0" width="14" height="28" />
      <rect class="seg" x="32" y="14" width="14" height="14" />
      <rect class="seg" x="48" y="4" width="14" height="24" />
      <rect class="seg" x="64" y="10" width="14" height="18" />
      <rect class="seg" x="80" y="2" width="14" height="26" />
      <rect class="seg" x="96" y="16" width="14" height="12" />
      <rect class="seg" x="112" y="8" width="14" height="20" />
      <rect class="seg" x="128" y="4" width="14" height="24" />
      <rect class="seg" x="144" y="0" width="14" height="28" />
      <rect class="seg" x="160" y="14" width="14" height="14" />
