<style>
  .visual-frame {
    background: #fafbfc;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 18px;
    margin: 8px 0 0;
  }
  .vlabel {
    font-size: 11px;
    color: var(--muted);
    margin-bottom: 8px;
    display: flex;
    justify-content: space-between;
  }
  .seg {
    fill: var(--seg-fill);
  }
  .lbl {
    font:
      10.5px 'JetBrains Mono',
      monospace;
    fill: var(--muted);
  }
  .lbl-strong {
    font:
      11px 'JetBrains Mono',
      monospace;
    fill: var(--ink);
    font-weight: 600;
  }
</style>
