      <rect class="seg" x="160" y="14" width="14" height="14" />
      <rect class="seg" x="176" y="18" width="14" height="10" />
      <rect class="seg" x="192" y="22" width="14" height="6" />
      <rect class="seg" x="208" y="6" width="14" height="22" />
      <rect class="seg" x="224" y="10" width="14" height="18" />
      <rect class="seg" x="240" y="2" width="14" height="26" />
    </g>
    <text class="lbl" x="10" y="208">→ encryption hides bytes; size and timing remain visible</text>
  </svg>
